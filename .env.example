# Discord user account token (required)
# Obtain from Discord client: Settings > Advanced > Enable Developer Mode,
# then open DevTools (Ctrl+Shift+I) and run: localStorage.token in the console
DISCORD_TOKEN=your_discord_token_here

# Absolute or relative path to the folder containing video files to stream
# Supported formats: .mp4, .mkv, .mov, .avi, .webm
VIDEO_FOLDER=C:\path\to\your\video\folder


# Discord server and channel IDs
GUILD_ID=your_guild_id_here
VOICE_CHANNEL_ID=your_voice_channel_id_here
TEXT_CHANNEL_ID=your_text_channel_id_here

# The Discord user ID allowed to control the bot
OWNER_ID=your_owner_id_here

# Optional: Discord role ID — members with this role can also use slash commands
# Leave empty to restrict slash commands to OWNER_ID only
ALLOWED_ROLE_ID=

# Optional: Discord webhook URL for now-playing embeds
WEBHOOK_URL=

# Optional: Spotify API credentials (required for !audio with Spotify links)
# Get from https://developer.spotify.com/dashboard → Create App
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: Discord bot integration
# Set to "true" to activate the bot (any other value or absence disables it)
DISCORD_BOT_ENABLED=false

# Discord bot token (required when DISCORD_BOT_ENABLED is "true")
# Obtain from the Discord Developer Portal: https://discord.com/developers/applications
# Create an application → Bot → Reset Token
DISCORD_BOT_TOKEN=
