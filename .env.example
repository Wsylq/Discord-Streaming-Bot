# Discord user account token (required)
# Obtain from Discord client: Settings > Advanced > Enable Developer Mode,
# then open DevTools (Ctrl+Shift+I) and run: localStorage.token in the console
DISCORD_TOKEN=your_discord_token_here

# Absolute or relative path to the folder containing video files to stream
# Supported formats: .mp4, .mkv, .mov, .avi, .webm
VIDEO_FOLDER=C:\path\to\your\video\folder


# Discord server and channel IDs
GUILD_ID=your_guild_id_here
VOICE_CHANNEL_ID=your_voice_channel_id_here
TEXT_CHANNEL_ID=your_text_channel_id_here

# The Discord user ID allowed to control the bot
OWNER_ID=your_owner_id_here
